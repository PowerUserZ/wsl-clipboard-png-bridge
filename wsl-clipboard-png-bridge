#!/usr/bin/env bash
# wsl-clipboard-png-bridge
#
# Poll the WSLg Wayland clipboard. When it contains image/bmp (as delivered by
# Windows screenshot tools such as Snipping Tool / Win+Shift+S) but not
# image/png, convert to PNG and publish the PNG to both the Wayland and the
# X11 clipboards. This lets WSL-side tools that only accept image/png (notably
# Claude Code — see anthropics/claude-code#25935) receive the screenshot.
#
# Why polling, not wl-paste --watch:
#   WSLg ships the Weston compositor, which does not implement the wlroots
#   data-control protocol required by wl-paste --watch. We fall back to a
#   short-interval poll.
#
# Trust model:
#   Anything the user can put on the Windows clipboard is treated as trusted
#   local input. The script runs as the current user, writes temp files with
#   0600 permissions (mktemp default), and feeds BMP bytes to ImageMagick with
#   a wall-clock timeout and explicit memory/map/disk limits to bound
#   memory/CPU on malformed input. Every blocking clipboard IPC call is
#   wrapped in `timeout "$io_timeout"` so a hung selection owner on either
#   side cannot freeze the loop.

set -euo pipefail

# --- configuration --------------------------------------------------------

# Poll interval in seconds. Accepts integer or decimal (e.g. 0.3, 1, 2.5).
# Reject anything that isn't a positive number so the value can't become a
# shell-injection vector when expanded into `sleep`.
interval="${CLIPBOARD_WATCH_INTERVAL:-0.3}"
if ! awk -v v="$interval" 'BEGIN { exit !(v ~ /^[0-9]+([.][0-9]+)?$/ && v > 0) }'; then
    echo "wsl-clipboard-png-bridge: invalid CLIPBOARD_WATCH_INTERVAL='$interval'; using 0.3" >&2
    interval="0.3"
fi

# Maximum seconds ImageMagick is allowed to spend on one conversion. Cheap
# defense against a malformed or pathologically large BMP hanging the daemon.
# Require a positive integer — `timeout 0` would fire immediately and break
# every conversion silently.
convert_timeout="${CLIPBOARD_CONVERT_TIMEOUT:-5}"
if ! [[ "$convert_timeout" =~ ^[1-9][0-9]*$ ]]; then
    echo "wsl-clipboard-png-bridge: invalid CLIPBOARD_CONVERT_TIMEOUT='$convert_timeout'; using 5" >&2
    convert_timeout="5"
fi

# Compute clipboard content signatures every N polls when MIME types are
# unchanged. This keeps back-to-back screenshot detection reliable while
# reducing hashing overhead in steady-state polling loops.
signature_every="${CLIPBOARD_SIGNATURE_EVERY:-3}"
if ! [[ "$signature_every" =~ ^[1-9][0-9]*$ ]]; then
    echo "wsl-clipboard-png-bridge: invalid CLIPBOARD_SIGNATURE_EVERY='$signature_every'; using 3" >&2
    signature_every="3"
fi

# Bound resource use while reading clipboard bytes for signatures so an
# unbounded stream cannot stall the daemon loop.
hash_timeout="${CLIPBOARD_HASH_TIMEOUT:-2}"
if ! [[ "$hash_timeout" =~ ^[1-9][0-9]*$ ]]; then
    echo "wsl-clipboard-png-bridge: invalid CLIPBOARD_HASH_TIMEOUT='$hash_timeout'; using 2" >&2
    hash_timeout="2"
fi

hash_max_bytes="${CLIPBOARD_HASH_MAX_BYTES:-8388608}"
if ! [[ "$hash_max_bytes" =~ ^[1-9][0-9]*$ ]]; then
    echo "wsl-clipboard-png-bridge: invalid CLIPBOARD_HASH_MAX_BYTES='$hash_max_bytes'; using 8388608" >&2
    hash_max_bytes="8388608"
fi

# Cap any single blocking clipboard IPC call (wl-paste / wl-copy / xclip).
# Without this, a hung clipboard owner on either side can freeze the daemon.
io_timeout="${CLIPBOARD_IO_TIMEOUT:-2}"
if ! [[ "$io_timeout" =~ ^[1-9][0-9]*$ ]]; then
    echo "wsl-clipboard-png-bridge: invalid CLIPBOARD_IO_TIMEOUT='$io_timeout'; using 2" >&2
    io_timeout="2"
fi

# Hard resource ceilings for the ImageMagick conversion, in addition to the
# wall-clock CLIPBOARD_CONVERT_TIMEOUT. Expressed in MiB and enforced via
# `convert -limit memory/map/disk`. Defaults comfortably handle a 4K BMP
# (~32 MiB raw) while bounding pathological inputs.
convert_memory_mb="${CLIPBOARD_CONVERT_MEMORY_MB:-256}"
if ! [[ "$convert_memory_mb" =~ ^[1-9][0-9]*$ ]]; then
    echo "wsl-clipboard-png-bridge: invalid CLIPBOARD_CONVERT_MEMORY_MB='$convert_memory_mb'; using 256" >&2
    convert_memory_mb="256"
fi

convert_disk_mb="${CLIPBOARD_CONVERT_DISK_MB:-512}"
if ! [[ "$convert_disk_mb" =~ ^[1-9][0-9]*$ ]]; then
    echo "wsl-clipboard-png-bridge: invalid CLIPBOARD_CONVERT_DISK_MB='$convert_disk_mb'; using 512" >&2
    convert_disk_mb="512"
fi

# --- single-instance guard ------------------------------------------------

# Hold an advisory lock on a per-user lock file for the daemon's lifetime.
# If another instance already owns it, exit quietly so duplicate invocations
# (from multiple login shells or a second install.sh run) are harmless.
LOCK_FILE="${WCPB_LOCK_FILE:-$HOME/.cache/wsl-clipboard-png-bridge.lock}"
mkdir -p "$(dirname "$LOCK_FILE")"
exec 9>"$LOCK_FILE"
if ! flock -n 9; then
    echo "wsl-clipboard-png-bridge: another instance is already running; exiting" >&2
    exit 0
fi

# --- dependency check -----------------------------------------------------

missing=()
for cmd in wl-paste wl-copy xclip convert timeout mktemp flock sha256sum wc; do
    command -v "$cmd" >/dev/null 2>&1 || missing+=("$cmd")
done
if (( ${#missing[@]} > 0 )); then
    printf 'wsl-clipboard-png-bridge: missing dependency: %s\n' "${missing[@]}" >&2
    echo "install with: sudo apt install -y wl-clipboard xclip imagemagick coreutils" >&2
    exit 1
fi

# --- temp-file hygiene ----------------------------------------------------

tmp=""
cleanup() {
    if [ -n "$tmp" ] && [ -e "$tmp" ]; then
        rm -f "$tmp"
    fi
}
trap cleanup EXIT
# On termination signals: run cleanup and exit explicitly — without the
# explicit exit, bash resumes the loop after the trap handler returns.
trap 'cleanup; exit 130' INT
trap 'cleanup; exit 143' TERM
trap 'cleanup; exit 129' HUP

# --- main loop ------------------------------------------------------------

# Signature = "<sha256 of first $hash_max_bytes bytes>-<total byte count>".
# Mixing the byte count defeats prefix-only collisions where two large images
# share an identical leading window (e.g. two 4K screenshots with the same
# taskbar region). Returns empty string on any read failure — callers must
# treat empty as "unknown, do not overwrite prior signature".
clipboard_signature() {
    local mime="$1"
    # Inner bash -c uses its own positional args ($1 MIME, $2 byte cap,
    # $3 io timeout). Intentional single-quoting of the body; $1 in awk is
    # an awk field reference. SC2016 is a false positive here.
    # shellcheck disable=SC2016
    timeout "$hash_timeout" bash -c '
        set -o pipefail
        hash="$(timeout "$3" wl-paste -t "$1" 2>/dev/null | head -c "$2" | sha256sum | awk "{print \$1}")" || exit 1
        size="$(timeout "$3" wl-paste -t "$1" 2>/dev/null | wc -c)" || exit 1
        [ -n "$hash" ] || exit 1
        printf "%s-%s\n" "$hash" "$size"
    ' _ "$mime" "$hash_max_bytes" "$io_timeout" 2>/dev/null || echo ""
}

last_types=""
last_signature=""
signature_tick=0

while true; do
    types="$(timeout "$io_timeout" wl-paste --list-types 2>/dev/null || true)"
    signature="$last_signature"

    has_png_wl=false
    grep -qx "image/png" <<<"$types" && has_png_wl=true

    has_bmp=false
    grep -qx "image/bmp" <<<"$types" && has_bmp=true

    should_hash=false
    if [ "$types" != "$last_types" ]; then
        should_hash=true
        signature_tick=0
    elif $has_png_wl || $has_bmp; then
        signature_tick=$((signature_tick + 1))
        if (( signature_tick >= signature_every )); then
            should_hash=true
            signature_tick=0
        fi
    else
        signature_tick=0
        signature=""
    fi

    # Trigger conversion not only when MIME types change, but also when image
    # bytes change while types stay the same (back-to-back Win+Shift+S
    # screenshots). Empty signatures mean "read failed" — do not overwrite
    # the last known-good value.
    if $should_hash; then
        new_sig=""
        if $has_png_wl; then
            new_sig="$(clipboard_signature "image/png")"
        elif $has_bmp; then
            new_sig="$(clipboard_signature "image/bmp")"
        fi
        if [ -n "$new_sig" ]; then
            signature="$new_sig"
        elif ! $has_png_wl && ! $has_bmp; then
            signature=""
        fi
    fi

    if [ "$types" != "$last_types" ] || [ "$signature" != "$last_signature" ]; then
        did_work=false

        if $has_png_wl || $has_bmp; then
            tmp="$(mktemp --suffix=.png)"
            ok=true

            if $has_png_wl; then
                timeout "$io_timeout" wl-paste -t image/png 2>/dev/null >"$tmp" || ok=false
            else
                # Bounded conversion: wall-clock timeout + memory/map/disk
                # ceilings; ignore pipe errors but check final size.
                if ! timeout "$io_timeout" wl-paste -t image/bmp 2>/dev/null \
                    | timeout "$convert_timeout" convert \
                        -limit memory "${convert_memory_mb}MiB" \
                        -limit map    "${convert_memory_mb}MiB" \
                        -limit disk   "${convert_disk_mb}MiB" \
                        bmp:- png:- \
                      >"$tmp" 2>/dev/null; then
                    ok=false
                fi
            fi

            if $ok && [ -s "$tmp" ]; then
                if ! $has_png_wl; then
                    timeout "$io_timeout" wl-copy -t image/png <"$tmp" 2>/dev/null || true
                fi
                timeout "$io_timeout" xclip -selection clipboard -t image/png -i "$tmp" 2>/dev/null || true
                did_work=true
            fi

            rm -f "$tmp"
            tmp=""
        fi

        # Only advance state when we either finished work or the clipboard
        # had no image for us to process. A failed conversion keeps the old
        # state so the next poll retries instead of silently dropping the
        # screenshot.
        if $did_work; then
            last_types="$(timeout "$io_timeout" wl-paste --list-types 2>/dev/null || true)"
            refreshed=""
            if $has_png_wl; then
                refreshed="$(clipboard_signature "image/png")"
            elif $has_bmp; then
                refreshed="$(clipboard_signature "image/bmp")"
            fi
            [ -n "$refreshed" ] && last_signature="$refreshed"
        elif ! $has_png_wl && ! $has_bmp; then
            last_types="$types"
            last_signature=""
        fi
    fi

    sleep "$interval"
done
