#!/usr/bin/env bash
# wsl-clipboard-png-bridge
#
# Poll the WSLg Wayland clipboard. When it contains image/bmp (as delivered by
# Windows screenshot tools such as Snipping Tool / Win+Shift+S) but not
# image/png, convert to PNG and publish the PNG to both the Wayland and the
# X11 clipboards. This lets WSL-side tools that only accept image/png (notably
# Claude Code — see anthropics/claude-code#25935) receive the screenshot.
#
# Why polling, not wl-paste --watch:
#   WSLg ships the Weston compositor, which does not implement the wlroots
#   data-control protocol required by wl-paste --watch. We fall back to a
#   short-interval poll.
#
# Trust model:
#   Anything the user can put on the Windows clipboard is treated as trusted
#   local input. The script runs as the current user, writes temp files with
#   0600 permissions (mktemp default), and feeds BMP bytes to ImageMagick with
#   a wall-clock timeout and explicit memory/map/disk limits to bound
#   memory/CPU on malformed input. Every blocking clipboard IPC call is
#   wrapped in `timeout "$io_timeout"` so a hung selection owner on either
#   side cannot freeze the loop.

set -euo pipefail

# --- configuration --------------------------------------------------------

# Active poll interval in seconds — used right after a successful conversion
# and for $active_window_sec seconds afterwards, then the daemon switches to
# $idle_interval to drop steady-state CPU. Accepts integer or decimal
# (e.g. 0.3, 1, 2.5). Reject anything that isn't a positive number so the
# value can't become a shell-injection vector when expanded into `sleep`.
# Name kept for backwards compatibility — pre-0.1.5 this was the only poll
# interval.
interval="${CLIPBOARD_WATCH_INTERVAL:-0.3}"
if ! awk -v v="$interval" 'BEGIN { exit !(v ~ /^[0-9]+([.][0-9]+)?$/ && v > 0) }'; then
    echo "wsl-clipboard-png-bridge: invalid CLIPBOARD_WATCH_INTERVAL='$interval'; using 0.3" >&2
    interval="0.3"
fi

# Idle poll interval (seconds). Used when no activity has occurred in the
# last $active_window_sec seconds. Defaults to 5x the active interval so the
# daemon is responsive after a screenshot but cheap when nothing is happening.
idle_interval="${CLIPBOARD_IDLE_INTERVAL:-1.5}"
if ! awk -v v="$idle_interval" 'BEGIN { exit !(v ~ /^[0-9]+([.][0-9]+)?$/ && v > 0) }'; then
    echo "wsl-clipboard-png-bridge: invalid CLIPBOARD_IDLE_INTERVAL='$idle_interval'; using 1.5" >&2
    idle_interval="1.5"
fi

# Seconds the daemon stays in active (fast) polling after a successful
# publish. Each successful conversion extends this window. Positive integer.
active_window_sec="${CLIPBOARD_ACTIVE_WINDOW_SEC:-5}"
if ! [[ "$active_window_sec" =~ ^[1-9][0-9]*$ ]]; then
    echo "wsl-clipboard-png-bridge: invalid CLIPBOARD_ACTIVE_WINDOW_SEC='$active_window_sec'; using 5" >&2
    active_window_sec="5"
fi

# Maximum seconds ImageMagick is allowed to spend on one conversion. Cheap
# defense against a malformed or pathologically large BMP hanging the daemon.
# Require a positive integer — `timeout 0` would fire immediately and break
# every conversion silently.
convert_timeout="${CLIPBOARD_CONVERT_TIMEOUT:-5}"
if ! [[ "$convert_timeout" =~ ^[1-9][0-9]*$ ]]; then
    echo "wsl-clipboard-png-bridge: invalid CLIPBOARD_CONVERT_TIMEOUT='$convert_timeout'; using 5" >&2
    convert_timeout="5"
fi

# Compute clipboard content signatures every N polls when MIME types are
# unchanged. This keeps back-to-back screenshot detection reliable while
# reducing hashing overhead in steady-state polling loops.
signature_every="${CLIPBOARD_SIGNATURE_EVERY:-3}"
if ! [[ "$signature_every" =~ ^[1-9][0-9]*$ ]]; then
    echo "wsl-clipboard-png-bridge: invalid CLIPBOARD_SIGNATURE_EVERY='$signature_every'; using 3" >&2
    signature_every="3"
fi

# Bound resource use while reading clipboard bytes for signatures so an
# unbounded stream cannot stall the daemon loop.
hash_timeout="${CLIPBOARD_HASH_TIMEOUT:-2}"
if ! [[ "$hash_timeout" =~ ^[1-9][0-9]*$ ]]; then
    echo "wsl-clipboard-png-bridge: invalid CLIPBOARD_HASH_TIMEOUT='$hash_timeout'; using 2" >&2
    hash_timeout="2"
fi

hash_max_bytes="${CLIPBOARD_HASH_MAX_BYTES:-8388608}"
if ! [[ "$hash_max_bytes" =~ ^[1-9][0-9]*$ ]]; then
    echo "wsl-clipboard-png-bridge: invalid CLIPBOARD_HASH_MAX_BYTES='$hash_max_bytes'; using 8388608" >&2
    hash_max_bytes="8388608"
fi

# Cap any single blocking clipboard IPC call (wl-paste / wl-copy / xclip).
# Without this, a hung clipboard owner on either side can freeze the daemon.
io_timeout="${CLIPBOARD_IO_TIMEOUT:-2}"
if ! [[ "$io_timeout" =~ ^[1-9][0-9]*$ ]]; then
    echo "wsl-clipboard-png-bridge: invalid CLIPBOARD_IO_TIMEOUT='$io_timeout'; using 2" >&2
    io_timeout="2"
fi

# Hard resource ceilings for the ImageMagick conversion, in addition to the
# wall-clock CLIPBOARD_CONVERT_TIMEOUT. Expressed in MiB and enforced via
# `convert -limit memory/map/disk`. Defaults comfortably handle a 4K BMP
# (~32 MiB raw) while bounding pathological inputs.
convert_memory_mb="${CLIPBOARD_CONVERT_MEMORY_MB:-256}"
if ! [[ "$convert_memory_mb" =~ ^[1-9][0-9]*$ ]]; then
    echo "wsl-clipboard-png-bridge: invalid CLIPBOARD_CONVERT_MEMORY_MB='$convert_memory_mb'; using 256" >&2
    convert_memory_mb="256"
fi

convert_disk_mb="${CLIPBOARD_CONVERT_DISK_MB:-512}"
if ! [[ "$convert_disk_mb" =~ ^[1-9][0-9]*$ ]]; then
    echo "wsl-clipboard-png-bridge: invalid CLIPBOARD_CONVERT_DISK_MB='$convert_disk_mb'; using 512" >&2
    convert_disk_mb="512"
fi

# --- structured debug logging (off by default) ----------------------------

# CLIPBOARD_DEBUG=1 turns on millisecond-stamped diagnostics on stderr at
# every decision point in the poll loop (mode selection, signature compute,
# convert outcome, publish outcome, state-cache update). Defined as a
# function so production runs pay only an empty-function call cost
# (~5 µs/poll) — no `date` fork unless debug is actually enabled.
#
# Activation:    CLIPBOARD_DEBUG=1 ./wsl-clipboard-png-bridge 2>~/wcpb.log
if [ "${CLIPBOARD_DEBUG:-0}" = "1" ]; then
    debug() { printf '[%s] %s\n' "$(date -u +%Y-%m-%dT%H:%M:%S.%3NZ)" "$*" >&2; }
else
    debug() { :; }
fi

# --- single-instance guard ------------------------------------------------

# Hold an advisory lock on a per-user lock file for the daemon's lifetime.
# If another instance already owns it, exit quietly so duplicate invocations
# (from multiple login shells or a second install.sh run) are harmless.
#
# WARNING — fd 9 inheritance:
#   `exec 9>FILE` does not set O_CLOEXEC, so any child process inherits fd 9
#   and keeps holding the advisory lock until its own fd is closed. Most
#   children we spawn are short-lived (wl-paste, convert, sha256sum) and exit
#   well before the daemon does, so the lock is effectively released along
#   with them. The two exceptions are `wl-copy` and `xclip`, which both
#   self-daemonize as the Wayland / X11 selection owner and outlive the
#   daemon. If they inherit fd 9 and the daemon dies, the lock stays held
#   by the still-running selection daemon, and a fresh daemon's `flock -n`
#   will report "another instance is already running" forever (until the
#   user manually kills the selection daemon or another client takes the
#   selection). To avoid that, every wl-copy / xclip invocation closes
#   fd 9 with `9>&-`. Do not remove those redirections.
LOCK_FILE="${WCPB_LOCK_FILE:-$HOME/.cache/wsl-clipboard-png-bridge.lock}"
mkdir -p "$(dirname "$LOCK_FILE")"
exec 9>"$LOCK_FILE"
if ! flock -n 9; then
    echo "wsl-clipboard-png-bridge: another instance is already running; exiting" >&2
    exit 0
fi

# --- dependency check -----------------------------------------------------

missing=()
for cmd in wl-paste wl-copy xclip convert timeout mktemp flock sha256sum wc; do
    command -v "$cmd" >/dev/null 2>&1 || missing+=("$cmd")
done
if (( ${#missing[@]} > 0 )); then
    printf 'wsl-clipboard-png-bridge: missing dependency: %s\n' "${missing[@]}" >&2
    echo "install with: sudo apt install -y wl-clipboard xclip imagemagick coreutils" >&2
    exit 1
fi

# --- temp-file hygiene ----------------------------------------------------

tmp=""
cleanup() {
    if [ -n "$tmp" ] && [ -e "$tmp" ]; then
        rm -f "$tmp"
    fi
}
trap cleanup EXIT
# On termination signals: run cleanup and exit explicitly — without the
# explicit exit, bash resumes the loop after the trap handler returns.
trap 'cleanup; exit 130' INT
trap 'cleanup; exit 143' TERM
trap 'cleanup; exit 129' HUP

# --- main loop ------------------------------------------------------------

# Signature = "<sha256 of first $hash_max_bytes bytes>-<total byte count>".
# Mixing the byte count defeats prefix-only collisions where two large images
# share an identical leading window (e.g. two 4K screenshots with the same
# taskbar region). Prints empty string on any read failure — callers must
# treat empty as "unknown, do not overwrite prior signature".
#
# Implementation notes:
#   * `() (...)` is a subshell-function: `set +o pipefail` inside is local to
#     this invocation and does not leak to the parent shell.
#   * pipefail is disabled here because `head -c N` closes its stdin once it
#     has the first N bytes, which makes tee's write to the >(...) target
#     fail with EPIPE. With pipefail on, the whole pipeline would exit
#     nonzero and signatures for any clipboard larger than $hash_max_bytes
#     would always come back empty (the exact scenario we care about — a
#     4K BMP is ~33 MiB, far larger than the 8 MiB default cap).
#   * Single wl-paste read: tee splits the stream into a truncated copy
#     (first $hash_max_bytes bytes → temp file → sha256) and the full stream
#     (→ wc -c → true total size). The previous version called wl-paste
#     twice, doubling clipboard IPC and racing on size-vs-hash drift.
#   * `tee -p` is REQUIRED. Default tee exits immediately on a write error
#     to any pipe; once `head -c N` closes its end of the >(...) pipe, tee
#     would stop forwarding to wc as well, and `size` would underreport
#     (only ~$hash_max_bytes + tee's kernel buffer). `-p` switches to
#     `warn-nopipe` so tee logs the broken pipe to stderr but keeps
#     streaming the rest to wc. Empirically verified with 16 MiB / 33 MiB
#     mock streams — without -p, total size came back as ~8.4 MiB.
#
# The function always exits 0 (printing nothing on failure) because callers
# use `var=$(clipboard_signature ...)` and the parent shell has `set -e`.
# A nonzero return from the substituted command would propagate and kill
# the daemon — empty stdout + exit 0 is the contract callers expect.
clipboard_signature() (
    set +o pipefail
    local mime="$1" tmp_hash hash size
    tmp_hash="$(mktemp 2>/dev/null)" || { echo ""; exit 0; }
    trap 'rm -f "$tmp_hash"' EXIT

    size="$(timeout "$hash_timeout" timeout "$io_timeout" wl-paste -t "$mime" 2>/dev/null \
        | tee -p >(head -c "$hash_max_bytes" >"$tmp_hash") 2>/dev/null \
        | wc -c)"

    if [[ "$size" =~ ^[0-9]+$ ]] && [ "$size" -gt 0 ] && [ -s "$tmp_hash" ]; then
        hash="$(sha256sum <"$tmp_hash" 2>/dev/null | cut -d' ' -f1)"
        [ -n "$hash" ] && printf '%s-%s\n' "$hash" "$size"
    fi
    exit 0
)

last_types=""
last_signature=""
signature_tick=0

# Adaptive polling state: $active_until is the epoch second at which the
# fast (interval) → slow (idle_interval) transition happens. Each successful
# publish bumps it to (now + active_window_sec) so a burst of screenshots
# stays in fast-poll mode without re-entering it on every event.
active_until=0

while true; do
    # Bash built-in printf %()T avoids forking `date` on every poll.
    printf -v now_s '%(%s)T' -1
    if (( now_s < active_until )); then
        current_interval="$interval"
        mode="active"
    else
        current_interval="$idle_interval"
        mode="idle"
    fi
    debug "tick mode=$mode interval=$current_interval now=$now_s active_until=$active_until"

    types="$(timeout "$io_timeout" wl-paste --list-types 2>/dev/null || true)"
    signature="$last_signature"

    # Cache the type-list comparison once instead of evaluating it 5 times
    # below. Bash arg expansion in `debug "...$([ ... ])..."` runs even when
    # debug() is the no-op stub, so direct boolean vars are required to
    # keep production cost at zero.
    if [ "$types" != "$last_types" ]; then
        types_changed=true
    else
        types_changed=false
    fi

    # `case` over `grep -qx <<<"$types"`: bash internal pattern matching
    # avoids 2 fork+exec per poll. Wrapping $types in literal newlines makes
    # the patterns match whole lines exactly (mimics `grep -x`), so a
    # hypothetical `image/png-foo` MIME line would not match `image/png`.
    has_png_wl=false
    has_bmp=false
    case $'\n'"$types"$'\n' in
        *$'\nimage/png\n'*) has_png_wl=true ;;
    esac
    case $'\n'"$types"$'\n' in
        *$'\nimage/bmp\n'*) has_bmp=true ;;
    esac

    debug "types has_png_wl=$has_png_wl has_bmp=$has_bmp types_changed=$types_changed"

    should_hash=false
    if $types_changed; then
        should_hash=true
        signature_tick=0
    elif $has_png_wl || $has_bmp; then
        signature_tick=$((signature_tick + 1))
        if (( signature_tick >= signature_every )); then
            should_hash=true
            signature_tick=0
        fi
    else
        signature_tick=0
        signature=""
    fi

    # Trigger conversion not only when MIME types change, but also when image
    # bytes change while types stay the same (back-to-back Win+Shift+S
    # screenshots). Empty signatures mean "read failed" — do not overwrite
    # the last known-good value.
    if $should_hash; then
        new_sig=""
        if $has_png_wl; then
            new_sig="$(clipboard_signature "image/png")"
        elif $has_bmp; then
            new_sig="$(clipboard_signature "image/bmp")"
        fi
        if [ -n "$new_sig" ]; then
            signature="$new_sig"
        elif ! $has_png_wl && ! $has_bmp; then
            signature=""
        fi
        if [ "$signature" != "$last_signature" ]; then sig_changed=true; else sig_changed=false; fi
        debug "hash should_hash=true tick=$signature_tick new=${new_sig:0:16}.. sig_changed=$sig_changed"
    fi

    if $types_changed || [ "$signature" != "$last_signature" ]; then
        did_work=false
        if $types_changed; then trigger_reason=types_changed; else trigger_reason=signature_changed; fi
        debug "trigger reason=$trigger_reason"

        if $has_png_wl || $has_bmp; then
            # `tmp=$(mktemp ...)` under set -e would kill the daemon on any
            # mktemp failure (TMPDIR full, EMFILE, denied perms). The whole
            # point of being a daemon is surviving transient host failures
            # and retrying on the next poll, so guard the substitution
            # explicitly: an empty $tmp lets the existing `[ -s "$tmp" ]`
            # publish gate skip the iteration cleanly, and `rm -f ""` is a
            # no-op so the trailing cleanup stays correct.
            ok=true
            if ! tmp="$(mktemp --suffix=.png 2>/dev/null)"; then
                tmp=""
                ok=false
                debug "mktemp failed (TMPDIR exhausted?); will retry next poll"
            fi

            if $ok && $has_png_wl; then
                timeout "$io_timeout" wl-paste -t image/png 2>/dev/null >"$tmp" || ok=false
            elif $ok; then
                # Bounded conversion: wall-clock timeout + memory/map/disk
                # ceilings; ignore pipe errors but check final size.
                if ! timeout "$io_timeout" wl-paste -t image/bmp 2>/dev/null \
                    | timeout "$convert_timeout" convert \
                        -limit memory "${convert_memory_mb}MiB" \
                        -limit map    "${convert_memory_mb}MiB" \
                        -limit disk   "${convert_disk_mb}MiB" \
                        bmp:- png:- \
                      >"$tmp" 2>/dev/null; then
                    ok=false
                fi
            fi
            # Pre-compute debug args: $(stat ...) would fork once per poll
            # even when DEBUG=0 (bash arg expansion happens before the
            # no-op stub returns). Cheap shortcut: only call stat when
            # debug is actually enabled.
            if [ "${CLIPBOARD_DEBUG:-0}" = "1" ]; then
                _dbg_size=$(stat -c%s "$tmp" 2>/dev/null || echo 0)
                if $has_png_wl; then _dbg_src=png_passthrough; else _dbg_src=bmp_to_png; fi
                debug "convert ok=$ok tmp_size=$_dbg_size source=$_dbg_src"
            fi

            if $ok && [ -s "$tmp" ]; then
                # Count the publish step as successful only when both consumer
                # paths are ready: Wayland must already hold PNG or accept our
                # wl-copy write, and X11 must accept the xclip mirror. If one
                # side fails transiently, keep `did_work=false` so the periodic
                # signature retry re-attempts the missing side instead of
                # caching an image that only reached half of the bridge.
                wayland_ready=false
                x11_ready=false
                wl_copy_status="fail"   # already_png|ok|fail
                if $has_png_wl; then
                    # Wayland already has PNG; we only need to mirror to X11.
                    wayland_ready=true
                    wl_copy_status="already_png"
                elif timeout "$io_timeout" wl-copy -t image/png <"$tmp" 2>/dev/null 9>&-; then
                    wayland_ready=true
                    wl_copy_status="ok"
                fi
                # 9>&- closes the lock fd in the wl-copy / xclip child before
                # exec — without it, the self-daemonizing selection owner
                # would inherit fd 9 and keep flock(2) held even after this
                # daemon exits. See the LOCK_FILE comment block.
                xclip_status="fail"
                if timeout "$io_timeout" xclip -selection clipboard -t image/png -i "$tmp" 2>/dev/null 9>&-; then
                    x11_ready=true
                    xclip_status="ok"
                fi
                if $wayland_ready && $x11_ready; then
                    did_work=true
                    # Extend the fast-poll window so back-to-back screenshots
                    # stay responsive without paying idle-poll latency for
                    # the second one. now_s is captured at the top of the
                    # loop iteration; using it here (vs. re-fetching) is
                    # close enough for human-perceptible latency budgeting.
                    active_until=$((now_s + active_window_sec))
                    # This iteration may have started in idle mode. Switch the
                    # sleep at the bottom of the same iteration to the active
                    # interval immediately after a successful publish.
                    current_interval="$interval"
                fi
                debug "publish wl_copy=$wl_copy_status xclip=$xclip_status wayland_ready=$wayland_ready x11_ready=$x11_ready did_work=$did_work"
            fi

            rm -f "$tmp"
            tmp=""
        fi

        # Only advance state when we either finished work or the clipboard
        # had no image for us to process. A failed conversion keeps the old
        # state so the next poll retries instead of silently dropping the
        # screenshot.
        if $did_work; then
            # Re-read types AFTER our writes — a BMP we just converted will
            # now appear as image/png on the Wayland clipboard, so we must
            # pick the signature MIME from the *refreshed* type list rather
            # than the pre-conversion has_png_wl/has_bmp flags. Otherwise
            # clipboard_signature("image/bmp") returns empty, last_signature
            # stays on the pre-write value, and the same PNG is re-published
            # about signature_every polls later.
            last_types="$(timeout "$io_timeout" wl-paste --list-types 2>/dev/null || true)"
            refreshed=""
            case $'\n'"$last_types"$'\n' in
                *$'\nimage/png\n'*) refreshed="$(clipboard_signature "image/png")" ;;
                *$'\nimage/bmp\n'*) refreshed="$(clipboard_signature "image/bmp")" ;;
            esac
            [ -n "$refreshed" ] && last_signature="$refreshed"
            debug "cache branch=advanced refreshed=${refreshed:0:16}.."
        elif $has_png_wl || $has_bmp; then
            # Conversion/read failed. Advance type state to avoid retrying on
            # every poll, but clear signature so a bounded retry still occurs
            # on the periodic signature hash tick.
            last_types="$types"
            last_signature=""
            debug "cache branch=retry_armed (convert/publish failed; signature cleared)"
        else
            last_types="$types"
            last_signature=""
            debug "cache branch=no_image"
        fi
    fi

    sleep "$current_interval"
done
